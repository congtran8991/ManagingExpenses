model BudgetCategory {
    id              Int     @id @default(autoincrement())
    periodId        Int     @map("period_id")
    name            String  @db.VarChar(100)
    allocatedAmount Decimal @default(0.00) @map("allocated_amount") @db.Decimal(15, 2)
    currentBalance  Decimal @default(0.00) @map("current_balance") @db.Decimal(15, 2)

    // Quan hệ (Relations)
    period             BudgetPeriod        @relation(fields: [periodId], references: [id], onDelete: Cascade)
    transactions       BudgetTransaction[]
    recurringTemplates RecurringTemplate[]

    @@map("budget_categories")
}

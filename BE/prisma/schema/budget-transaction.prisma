model BudgetTransaction {
    id               Int             @id @default(autoincrement())
    walletId         Int             @map("wallet_id")
    periodId         Int             @map("period_id")
    budgetCategoryId Int?            @map("budget_category_id")
    type             TransactionType
    amount           Decimal         @db.Decimal(15, 2)
    note             String?         @db.Text
    transactionDate  DateTime        @default(now()) @map("transaction_date") @db.Timestamp(0)

    // Audit Logs (UTC+0)
    createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
    updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(0)
    createdBy Int      @map("created_by")
    updatedBy Int      @map("updated_by")

    // Quan hệ (Relations)
    wallet         Wallet                  @relation(fields: [walletId], references: [id], onDelete: Cascade)
    period         BudgetPeriod            @relation(fields: [periodId], references: [id], onDelete: Cascade)
    budgetCategory BudgetCategory?         @relation(fields: [budgetCategoryId], references: [id], onDelete: Cascade)
    attachments    TransactionAttachment[]

    @@map("budget_transactions")
}

enum TransactionType {
    income
    allocate
    expense
    transfer
}

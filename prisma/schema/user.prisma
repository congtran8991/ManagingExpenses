model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  boards      Board[]  @relation("BoardMembers")
  ownedBoards Board[]  @relation("BoardOwner")
  cards       Card[]   @relation("CardAssignees")

  @@map("users")
}

model List {
  id        String   @id @default(uuid())
  title     String
  position  Int      // For ordering columns/lists
  boardId   String
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cards     Card[]

  @@map("lists")
}

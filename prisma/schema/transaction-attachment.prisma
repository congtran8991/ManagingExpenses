model TransactionAttachment {
    id            Int     @id @default(autoincrement())
    transactionId Int     @map("transaction_id")
    fileUrl       String  @map("file_url") @db.VarChar(255)
    fileType      String? @map("file_type") @db.VarChar(50)

    // Audit Logs (UTC+0)
    uploadedAt DateTime @default(now()) @map("uploaded_at") @db.Timestamp(0)
    updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamp(0)
    createdBy  Int      @map("created_by")
    updatedBy  Int      @map("updated_by")

    // Quan hệ (Relations)
    transaction BudgetTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

    @@map("transaction_attachments")
}
